% References for Review Article
% BibTeX格式模板

% ===== 基础格式示例 =====

% 期刊文章
@article{example2024,
  title={Example article title},
  author={Last, First and Last, First},
  journal={Journal Name},
  volume={1},
  number={1},
  pages={1--10},
  year={2024},
  publisher={Publisher},
  doi={10.xxxx/xxx}
}

% 会议论文
@inproceedings{example2024conference,
  title={Example conference paper},
  author={Last, First},
  booktitle={Conference Name},
  pages={1--10},
  year={2024},
  organization={Organization}
}

% 预印本
@article{example2024preprint,
  title={Example preprint},
  author={Last, First},
  journal={arXiv preprint arXiv:2401.xxxxx},
  year={2024}
}

% 书籍
@book{example2024book,
  title={Example Book},
  author={Last, First},
  year={2024},
  publisher={Publisher}
}

% 书籍章节
@incollection{example2024chapter,
  title={Example chapter},
  author={Last, First},
  booktitle={Book Title},
  pages={1--10},
  year={2024},
  publisher={Publisher}
}

% 数据库
@article{database2024,
  title={Database name: description},
  author={Last, First and others},
  journal={Nucleic Acids Research},
  volume={52},
  pages={D1--D10},
  year={2024},
  publisher={Oxford University Press}
}

% 综述文章
@article{review2024,
  title={Review article title},
  author={Last, First},
  journal={Nature Reviews},
  volume={1},
  pages={1--15},
  year={2024}
}

% ===== 引用Key命名规范 =====
% 格式: 第一作者姓氏年份[关键词]
% 示例:
%   jumper2021alphafold - AlphaFold2
%   watson2023rfdiffusion - RFdiffusion
%   chen2024survey - 综述
%   smith2024method - 方法论文

% ===== 常见期刊缩写 =====
% Nature → Nature
% Science → Science
% Nature Methods → Nat. Methods
% Bioinformatics → Bioinformatics
% Nucleic Acids Research → Nucleic Acids Res.
% PNAS → Proc. Natl. Acad. Sci. USA

% ===== 特殊字符处理 =====
% 闭括号需要用{...}包裹
% 示例: title={The {AlphaFold} method}

% ===== 多作者处理 =====
% 使用 "and others" 或 "et al."
% author={First, Last and Second, Last and others}
