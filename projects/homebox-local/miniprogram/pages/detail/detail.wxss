/* pages/detail/detail.wxss */
.container {
  padding: 20rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

.loading, .empty {
  text-align: center;
  padding: 100rpx;
  color: #999;
}

/* 列表模式 */
.list-mode {
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.list-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.list-count {
  font-size: 26rpx;
  color: #999;
}

.items-list {
  display: flex;
  flex-direction: column;
}

.item-card {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.item-card:last-child {
  border-bottom: none;
}

.item-card:active {
  background: #f9f9f9;
}

.item-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.item-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.item-quantity {
  font-size: 28rpx;
  color: #FF6B35;
}

.item-location {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.item-date {
  font-size: 24rpx;
  color: #999;
}

/* 详情模式 */
.detail-mode {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
}

.photos {
  width: 100%;
}

.photo-swiper {
  width: 100%;
  height: 400rpx;
}

.photo {
  width: 100%;
  height: 100%;
}

.info-section {
  padding: 30rpx;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.detail-quantity {
  font-size: 32rpx;
  color: #FF6B35;
  font-weight: bold;
}

.info-row {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  width: 180rpx;
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.info-value.desc {
  word-break: break-all;
  line-height: 1.6;
}

.category-tag {
  background: #FFF3E0;
  color: #FF6B35;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  background: #f0f0f0;
  color: #666;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

/* 操作按钮 */
.detail-actions {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.btn-edit, .btn-delete {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
}

.btn-edit {
  background: #FF6B35;
  color: white;
}

.btn-delete {
  background: white;
  color: #ff4d4f;
  border: 1rpx solid #ff4d4f;
}

.btn-icon {
  font-size: 28rpx;
}
