/* pages/home/home.wxss */
.container {
  padding: 20rpx;
  padding-bottom: 180rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

/* 引导遮罩 */
.guide-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.guide-content {
  background: white;
  border-radius: 24rpx;
  padding: 50rpx;
  margin: 40rpx;
  text-align: center;
}

.guide-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.guide-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.guide-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 32rpx;
}

.guide-steps {
  text-align: left;
  margin-bottom: 40rpx;
}

.step {
  font-size: 28rpx;
  color: #333;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.guide-btn {
  background: #FF6B35;
  color: white;
  font-size: 32rpx;
  padding: 24rpx 80rpx;
  border-radius: 40rpx;
  border: none;
}

/* 快捷入口 */
.quick-actions {
  display: flex;
  justify-content: space-between;
  background: white;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  font-size: 36rpx;
}

.action-icon.add {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C5A 100%);
  color: white;
  font-size: 48rpx;
  font-weight: bold;
}

.action-icon.ai {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.action-icon.search {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
}

.action-icon.location {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.action-text {
  font-size: 24rpx;
  color: #666;
}

/* 控制栏 */
.control-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: white;
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 20rpx;
}

.view-toggle {
  display: flex;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 6rpx;
}

.toggle-item {
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  color: #666;
  border-radius: 10rpx;
}

.toggle-item.active {
  background: #FF6B35;
  color: white;
}

.sort-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
}

.sort-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.sort-text {
  font-size: 24rpx;
  color: #666;
}

/* 分类筛选 */
.category-filter, .location-filter {
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.category-scroll, .location-scroll {
  white-space: nowrap;
}

.category-item, .location-item {
  display: inline-block;
  padding: 16rpx 28rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  margin-right: 16rpx;
}

.category-item.active, .location-item.active {
  background: #FF6B35;
  color: white;
}

.count {
  font-size: 22rpx;
  margin-left: 8rpx;
  opacity: 0.8;
}

/* 物品列表 */
.items-list {
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
}

.loading {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-title {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.empty-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.empty-btn {
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
  background: #f5f5f5;
  color: #666;
}

.empty-btn.primary {
  background: #FF6B35;
  color: white;
}

.result-count {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.item-card {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.item-card:last-child {
  border-bottom: none;
}

.item-card:active {
  background: #fafafa;
}

.item-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.item-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.item-quantity {
  font-size: 26rpx;
  color: #FF6B35;
}

.item-meta {
  display: flex;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.item-category {
  background: #FFF3E0;
  color: #FF6B35;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.item-location {
  background: #E3F2FD;
  color: #2196F3;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.item-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-date {
  font-size: 24rpx;
  color: #999;
}

.item-tags {
  display: flex;
  gap: 10rpx;
}

.tag {
  background: #f0f0f0;
  color: #666;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
}

/* 排序选择器 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.picker-content {
  width: 100%;
  background: white;
  border-radius: 24rpx 24rpx 0 0;
  padding: 30rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

.picker-title {
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.picker-item {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.picker-item.selected .picker-label {
  color: #FF6B35;
  font-weight: bold;
}

.picker-label {
  margin-left: 16rpx;
  font-size: 30rpx;
  color: #333;
}

.picker-close {
  margin-top: 20rpx;
  width: 100%;
  padding: 24rpx;
  background: #f5f5f5;
  color: #666;
  font-size: 30rpx;
  border-radius: 12rpx;
  border: none;
}

/* 悬浮按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 180rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C5A 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.4);
}

.fab:active {
  transform: scale(0.95);
}

.fab-icon {
  color: white;
  font-size: 48rpx;
  font-weight: bold;
}
