/* pages/location/location.wxss */
.container {
  padding: 20rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: white;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.add-btn {
  background: #07C160;
  color: white;
  font-size: 28rpx;
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
}

.empty {
  text-align: center;
  padding: 100rpx;
  color: #999;
}

.room-card {
  background: white;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.room-header {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.room-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.room-name {
  flex: 1;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.expand-icon {
  color: #999;
  font-size: 24rpx;
}

.room-content {
  padding: 20rpx 30rpx;
  background: #fafafa;
}

.action-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.mini-btn {
  background: #e8f5e9;
  color: #07C160;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.delete-btn {
  color: #ff4d4f;
  font-size: 24rpx;
}

.furniture-item {
  background: white;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.furniture-header {
  display: flex;
  align-items: center;
  padding: 20rpx;
}

.furniture-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.furniture-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.furniture-content {
  padding: 16rpx 20rpx;
  background: #f9f9f9;
}

.box-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: white;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.box-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.box-name {
  flex: 1;
  font-size: 26rpx;
  color: #666;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 80%;
  background: white;
  border-radius: 16rpx;
  padding: 40rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
}

.modal-input {
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.modal-btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.modal-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.modal-btn.confirm {
  background: #07C160;
  color: white;
}
