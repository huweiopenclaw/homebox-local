/* pages/ai-settings/ai-settings.wxss */
.container {
  padding: 20rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #999;
}

.config-form {
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.form-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.required {
  color: #ff4d4f;
  margin-left: 8rpx;
  font-size: 28rpx;
}

.form-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 80rpx;
  padding: 20rpx 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 26rpx;
  box-sizing: border-box;
  line-height: 1.5;
}

.url-input {
  font-size: 24rpx;
  word-break: break-all;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 80rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.arrow {
  color: #ccc;
  font-size: 32rpx;
}

.api-key-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.flex-1 {
  flex: 1;
}

.toggle-btn {
  padding: 16rpx 20rpx;
  font-size: 32rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.test-section {
  padding: 30rpx 0;
}

.test-btn {
  background: #e8f5e9;
  color: #07C160;
  font-size: 30rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  border: none;
}

.test-result {
  display: block;
  margin-top: 20rpx;
  font-size: 26rpx;
  text-align: center;
  padding: 16rpx;
  border-radius: 8rpx;
}

.test-result.success {
  background: #e8f5e9;
  color: #07C160;
}

.test-result.error {
  background: #fff5f5;
  color: #ff4d4f;
}

.help-section {
  margin-bottom: 20rpx;
}

.help-card {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.help-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.help-examples {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.example-item {
  display: flex;
  flex-direction: column;
  padding: 16rpx;
  background: #fafafa;
  border-radius: 8rpx;
}

.example-name {
  font-size: 26rpx;
  color: #FF6B35;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.example-url {
  font-size: 22rpx;
  color: #666;
  word-break: break-all;
  margin-bottom: 4rpx;
}

.example-model {
  font-size: 22rpx;
  color: #07C160;
}

.help-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: white;
  border-radius: 16rpx;
}

.help-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.help-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background: white;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
}

.save-btn {
  background: #FF6B35;
  color: white;
  font-size: 32rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  border: none;
}
