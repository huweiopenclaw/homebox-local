/* pages/edit-item/edit-item.wxss */
.container {
  padding: 20rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

.form-card {
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
}

.form-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.input {
  font-size: 32rpx;
  color: #333;
}

.textarea {
  width: 100%;
  height: 150rpx;
  font-size: 28rpx;
  color: #333;
}

.picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 32rpx;
  color: #333;
}

.arrow {
  color: #999;
  font-size: 32rpx;
}

.btn-group {
  padding: 20rpx;
}

.btn-save {
  background: #FF6B35;
  color: white;
  font-size: 32rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.btn-delete {
  background: white;
  color: #ff4d4f;
  font-size: 32rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  border: 1rpx solid #ff4d4f;
}
