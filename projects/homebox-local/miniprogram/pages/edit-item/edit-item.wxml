<!--pages/edit-item/edit-item.wxml-->
<view class="container">
  <view class="form-card">
    <view class="form-item">
      <text class="label">物品名称 *</text>
      <input class="input" placeholder="请输入物品名称" value="{{name}}" bindinput="onNameInput" />
    </view>

    <view class="form-item">
      <text class="label">数量</text>
      <input class="input" type="number" placeholder="1" value="{{quantity}}" bindinput="onQuantityChange" />
    </view>

    <view class="form-item">
      <text class="label">分类</text>
      <picker mode="selector" range="{{categories}}" range-key="name" bindchange="onCategoryChange">
        <view class="picker">
          {{selectedCategory || '请选择分类'}}
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">位置</text>
      <view class="picker" bindtap="onSelectLocation">
        {{selectedLocationName || '请选择位置'}}
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="form-item">
      <text class="label">描述</text>
      <textarea class="textarea" placeholder="添加描述（选填）" value="{{description}}" bindinput="onDescriptionInput" />
    </view>

    <view class="form-item">
      <text class="label">标签</text>
      <input class="input" placeholder="多个标签用逗号分隔" value="{{tags}}" bindinput="onTagsInput" />
    </view>
  </view>

  <view class="btn-group">
    <button class="btn-save" bindtap="onSave">保存修改</button>
    <button class="btn-delete" bindtap="onDelete">删除物品</button>
  </view>
</view>
