<!--pages/ai-scan/ai-scan.wxml-->
<view class="container">
  <!-- 拍照区域 -->
  <view class="photo-section">
    <view wx:if="{{!hasPhoto}}" class="photo-placeholder" bindtap="onTakePhoto">
      <text class="photo-icon">📷</text>
      <text class="photo-text">点击拍摄箱子照片</text>
      <text class="photo-hint">AI 将识别箱子中的所有物品</text>
    </view>
    
    <view wx:else class="photo-preview">
      <image class="preview-image" src="{{photoPath}}" mode="aspectFill" />
      <view class="photo-actions">
        <button class="retake-btn" bindtap="onRetake">重新拍照</button>
        <button class="recognize-btn" bindtap="onStartRecognize" loading="{{recognizing}}">
          {{recognizing ? '识别中...' : '开始识别'}}
        </button>
      </view>
    </view>
  </view>

  <!-- 错误提示 -->
  <view wx:if="{{error}}" class="error-section">
    <text class="error-icon">⚠️</text>
    <text class="error-text">{{error}}</text>
    <text class="settings-link" bindtap="onGoSettings">检查设置</text>
  </view>

  <!-- 识别结果 -->
  <view wx:if="{{recognizedItems.length > 0}}" class="result-section">
    <view class="result-header">
      <text class="result-title">识别结果 ({{recognizedItems.length}} 个物品)</text>
      <text class="select-all" bindtap="onToggleAll">
        {{selectedItems.length === recognizedItems.length ? '取消全选' : '全选'}}
      </text>
    </view>

    <view class="items-list">
      <view 
        wx:for="{{recognizedItems}}" 
        wx:key="id" 
        class="item-row {{selectedItems.indexOf(item.id) >= 0 ? 'selected' : ''}}"
        data-id="{{item.id}}"
        bindtap="onToggleItem">
        <view class="item-checkbox">
          <text>{{selectedItems.indexOf(item.id) >= 0 ? '✅' : '⬜'}}</text>
        </view>
        <view class="item-info">
          <view class="item-name">{{item.name}}</view>
          <view class="item-meta">
            <text class="item-category">{{item.category}}</text>
            <text class="item-quantity">×{{item.quantity}}</text>
          </view>
        </view>
        <view class="item-edit" catchtap="onEditItem" data-id="{{item.id}}">
          <text>✏️</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 位置选择 -->
  <view wx:if="{{recognizedItems.length > 0}}" class="location-section">
    <text class="section-title">存放位置</text>
    <picker mode="selector" range="{{locations}}" range-key="text" value="{{locationIndex}}" bindchange="onLocationChange">
      <view class="location-picker">
        <text class="{{locationIndex >= 0 ? 'location-value' : 'location-placeholder'}}">
          📍 {{locationText}}
        </text>
        <text class="arrow">›</text>
      </view>
    </picker>
  </view>

  <!-- 保存按钮 -->
  <view wx:if="{{selectedItems.length > 0}}" class="bottom-bar">
    <button class="save-btn" bindtap="onSaveItems" loading="{{saving}}">
      保存 {{selectedItems.length}} 个物品
    </button>
  </view>
</view>
