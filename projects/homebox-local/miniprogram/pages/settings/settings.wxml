<!--pages/settings/settings.wxml-->
<view class="container">
  <!-- AI 识别设置 -->
  <view class="settings-card">
    <view class="card-title">🤖 AI 识别</view>
    <view class="setting-item" bindtap="onAISettingsTap">
      <view class="setting-left">
        <text class="setting-label">AI 识别设置</text>
        <text class="setting-desc" wx:if="{{aiConfig.enabled}}">已启用 - {{aiConfig.provider}}</text>
        <text class="setting-desc disabled" wx:else>未配置</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 通用设置 -->
  <view class="settings-card">
    <view class="card-title">⚙️ 通用设置</view>
    <view class="setting-item">
      <text class="setting-label">通知提醒</text>
      <switch checked="{{settings.notifications}}" bindchange="onNotificationChange" color="#FF6B35"/>
    </view>

    <view class="setting-item">
      <text class="setting-label">深色模式</text>
      <switch checked="{{settings.darkMode}}" bindchange="onDarkModeChange" color="#FF6B35"/>
    </view>

    <view class="setting-item">
      <text class="setting-label">语言</text>
      <text class="setting-value">简体中文</text>
    </view>
  </view>

  <!-- 数据管理 -->
  <view class="settings-card">
    <view class="card-title">📊 数据管理</view>
    <view class="setting-item clickable" bindtap="onClearCache">
      <text class="setting-label danger">清除缓存</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="version">
    <text>HomeBox Local v1.0.0</text>
    <text class="sub">纯本地家庭物品管理</text>
  </view>
</view>
