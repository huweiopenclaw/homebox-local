/* pages/category/category.wxss */
.container {
  padding: 20rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

.loading {
  text-align: center;
  padding: 100rpx;
  color: #999;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.category-card {
  width: calc(33.33% - 14rpx);
  background: white;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.category-card:active {
  transform: scale(0.98);
  background: #f9f9f9;
}

.category-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.category-name {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.category-count {
  font-size: 24rpx;
  color: #999;
}

/* 添加分类卡片 */
.add-card {
  border: 2rpx dashed #ddd;
  background: #fafafa;
  justify-content: center;
}

.add-icon {
  font-size: 48rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.add-card .category-name {
  color: #999;
  font-weight: normal;
}
