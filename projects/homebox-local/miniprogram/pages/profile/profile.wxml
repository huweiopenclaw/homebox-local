<!--pages/profile/profile.wxml-->
<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-avatar">📦</view>
    <view class="user-info">
      <text class="user-name">HomeBox 用户</text>
      <text class="user-desc">管理你的家庭物品</text>
    </view>
  </view>

  <!-- 数据统计 -->
  <view class="stats-card">
    <view class="stat-item" bindtap="onLocationTap">
      <text class="stat-value">{{locationCount}}</text>
      <text class="stat-label">位置</text>
    </view>
    <view class="stat-item" bindtap="onCategoryTap">
      <text class="stat-value">{{categoryCount}}</text>
      <text class="stat-label">分类</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{itemCount}}</text>
      <text class="stat-label">物品</text>
    </view>
  </view>

  <!-- AI 状态 -->
  <view class="ai-card" bindtap="onAISettingsTap">
    <view class="ai-left">
      <text class="ai-icon">🤖</text>
      <view class="ai-info">
        <text class="ai-title">AI 识别</text>
        <text class="ai-status {{aiEnabled ? 'enabled' : 'disabled'}}">
          {{aiEnabled ? '已启用' : '未启用'}}
        </text>
      </view>
    </view>
    <text class="arrow">›</text>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-card">
    <view class="menu-item" bindtap="onLocationTap">
      <text class="menu-icon">📍</text>
      <text class="menu-text">位置管理</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onCategoryTap">
      <text class="menu-icon">📂</text>
      <text class="menu-text">分类管理</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onBatchEditTap">
      <text class="menu-icon">✅</text>
      <text class="menu-text">批量管理</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onBackupTap">
      <text class="menu-icon">💾</text>
      <text class="menu-text">数据备份</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onSettingsTap">
      <text class="menu-icon">⚙️</text>
      <text class="menu-text">设置</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 其他 -->
  <view class="menu-card">
    <view class="menu-item" bindtap="onAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onClearCache">
      <text class="menu-icon">🗑️</text>
      <text class="menu-text">清除缓存</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="version">
    <text>HomeBox Local v1.0.0</text>
  </view>
</view>
