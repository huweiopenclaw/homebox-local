/* pages/add-item/add-item.wxss */

.container {
  padding: 20rpx;
  padding-bottom: 300rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

/* 表单区块 */
.form-section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.label-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.required {
  color: #ff4444;
  margin-left: 8rpx;
  font-size: 28rpx;
}

/* 输入框 */
.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
}

.form-input::placeholder {
  color: #999;
}

/* 选择器 */
.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 80rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.picker-placeholder {
  font-size: 30rpx;
  color: #999;
}

.picker-value {
  font-size: 30rpx;
  color: #333;
}

.picker-arrow {
  font-size: 36rpx;
  color: #999;
  font-weight: bold;
}

.picker-disabled {
  opacity: 0.5;
}

/* 无位置提示 */
.no-location-tip {
  text-align: center;
  padding: 40rpx 20rpx;
  background: #fff9f5;
  border-radius: 12rpx;
  border: 1rpx dashed #FF6B35;
}

.tip-text {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.add-location-btn {
  background: #FF6B35;
  color: white;
  font-size: 28rpx;
  padding: 16rpx 40rpx;
  border-radius: 30rpx;
  border: none;
}

.add-location-link {
  text-align: center;
  padding: 20rpx;
  margin-top: 16rpx;
  color: #FF6B35;
  font-size: 26rpx;
}

/* 位置选择器组 */
.location-selectors {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.location-picker {
  background: #f5f5f5;
}

.location-display {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  padding: 20rpx;
  background: #e8f5e9;
  border-radius: 12rpx;
}

.location-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.location-text {
  font-size: 28rpx;
  color: #07C160;
}

/* 数量输入 */
.quantity-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.quantity-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #07C160;
  border-radius: 12rpx;
  color: white;
  font-size: 40rpx;
  font-weight: bold;
}

.quantity-btn:active {
  background: #06ad56;
  transform: scale(0.95);
}

.quantity-input {
  flex: 1;
  height: 80rpx;
  text-align: center;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 32rpx;
  color: #333;
}

/* 照片区域 */
.photo-section {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.photo-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.photo-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.photo-preview {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  object-fit: cover;
}

.photo-delete {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 48rpx;
  height: 48rpx;
  background: #ff4444;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.photo-delete text {
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  line-height: 1;
}

.photo-btn {
  width: 160rpx;
  height: 160rpx;
  background: #f5f5f5;
  border: 2rpx dashed #ccc;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.photo-btn:active {
  background: #eee;
}

.photo-icon {
  font-size: 48rpx;
}

.photo-text {
  font-size: 24rpx;
  color: #999;
}

.photo-tip {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999;
}

/* 多行文本 */
.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
}

.char-count {
  display: block;
  text-align: right;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999;
}

/* 按钮 */
.form-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx;
  background: white;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-save {
  width: 100%;
  height: 88rpx;
  background: #FF6B35;
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-save:active {
  background: #e55a2b;
}

.btn-save[loading] {
  background: #FF6B35;
  opacity: 0.8;
}

.btn-cancel {
  width: 100%;
  height: 88rpx;
  background: #f5f5f5;
  color: #666;
  font-size: 32rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-cancel:active {
  background: #eee;
}
