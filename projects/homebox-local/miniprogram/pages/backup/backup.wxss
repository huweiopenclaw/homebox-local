/* pages/backup/backup.wxss */
.container {
  padding: 20rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

/* 统计卡片 */
.stats-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 40rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  margin-bottom: 20rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255,255,255,0.3);
}

/* 信息卡片 */
.info-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
}

/* 操作卡片 */
.action-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.action-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.action-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.action-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.action-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 24rpx;
}

.action-btn {
  width: 100%;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  border: none;
}

.export-btn {
  background: #07C160;
  color: white;
}

.import-btn {
  background: #FF6B35;
  color: white;
}

/* 其他选项 */
.other-card {
  background: white;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.other-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
}

.other-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.other-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.other-arrow {
  color: #ccc;
  font-size: 32rpx;
}

/* 危险区域 */
.danger-card {
  background: #fff5f5;
  border-radius: 16rpx;
  padding: 30rpx;
  border: 1rpx solid #ffcccc;
}

.danger-header {
  font-size: 28rpx;
  color: #ff4444;
  margin-bottom: 20rpx;
}

.danger-btn {
  width: 100%;
  padding: 24rpx;
  background: white;
  color: #ff4444;
  font-size: 28rpx;
  border-radius: 12rpx;
  border: 1rpx solid #ff4444;
}
